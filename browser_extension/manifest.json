{
  "manifest_version": 3,
  "name": "YTGrab - Video Downloader",
  "version": "1.0.0",
  "description": "Download videos from YouTube and social media platforms. Like IDM, detects videos and shows download buttons.",
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:19850/*",
    "http://localhost:19850/*",
    "*://*.youtube.com/*",
    "*://*.youtu.be/*",
    "*://*.instagram.com/*",
    "*://*.facebook.com/*",
    "*://*.twitter.com/*",
    "*://*.x.com/*",
    "*://*.tiktok.com/*",
    "*://*.vimeo.com/*",
    "*://*.dailymotion.com/*",
    "*://*.twitch.tv/*",
    "*://*.reddit.com/*",
    "*://*.bilibili.com/*",
    "*://*.soundcloud.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.youtube.com/*",
        "*://*.youtu.be/*",
        "*://*.instagram.com/*",
        "*://*.facebook.com/*",
        "*://*.twitter.com/*",
        "*://*.x.com/*",
        "*://*.tiktok.com/*",
        "*://*.vimeo.com/*",
        "*://*.dailymotion.com/*",
        "*://*.twitch.tv/*",
        "*://*.reddit.com/*",
        "*://*.bilibili.com/*",
        "*://*.soundcloud.com/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_end"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
